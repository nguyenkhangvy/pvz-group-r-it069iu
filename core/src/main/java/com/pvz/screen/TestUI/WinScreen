package com.pvz.screen;

import com.badlogic.gdx.Gdx;
import com.badlogic.gdx.graphics.Color;
import com.badlogic.gdx.graphics.g2d.BitmapFont;
import com.badlogic.gdx.graphics.g2d.GlyphLayout;
import com.badlogic.gdx.scenes.scene2d.Actor;
import com.badlogic.gdx.scenes.scene2d.Stage;
import com.badlogic.gdx.scenes.scene2d.ui.*;
import com.badlogic.gdx.scenes.scene2d.utils.ChangeListener;
import com.pvz.core.GameConfig;
import com.pvz.data.LevelData;
import com.pvz.manager.DataManager;
import com.pvz.manager.SaveManager;
import com.pvz.manager.ScreenManager;
import com.pvz.util.DebugDraw;


public class WinScreen extends BaseScreen {

    private final int level;
    private final Stage stage;
    private static final Color BG      = new Color(0.10f, 0.25f, 0.05f, 1f);
    private static final Color GOLD    = new Color(1.00f, 0.85f, 0.10f, 1f);
    private static final Color GREEN   = new Color(0.55f, 0.95f, 0.35f, 1f);
    private BitmapFont bigFont;
    private final GlyphLayout layout = new GlyphLayout();

    WinScreen(int level) {
        this.level = level;
        stage = new Stage(viewport, batch);
        Gdx.input.setInputProcessor(stage);
        bigFont = new BitmapFont();
        bigFont.getData().setScale(2.4f);

        boolean wasLast = level >= GameConfig.LAST_LEVEL;
        SaveManager.get().onLevelWon(level);
        build(wasLast);
    }

    private void build(boolean wasLast) {
        Table root = new Table();
        root.setFillParent(true);
        root.center();

        root.add().height(160).row(); // khoang cho banner ve tay

        LevelData ld = DataManager.get().level(level);
        if (ld != null) {
            if (ld.unlockPlant != null) {
                Label l = new Label("New Plant unlocked: " + ld.unlockPlant, UiAssets.skin(), "subtitle");
                l.setColor(GREEN);
                root.add(l).padBottom(8).row();
            }
            if (ld.unlockZombie != null) {
                Label l = new Label("New Zombie: " + ld.unlockZombie, UiAssets.skin(), "subtitle");
                root.add(l).padBottom(8).row();
            }
            if (ld.unlockFeature != null) {
                Label l = new Label("New Feature: " + ld.unlockFeature, UiAssets.skin(), "subtitle");
                root.add(l).padBottom(8).row();
            }
        }
        root.add().height(20).row();

        if (wasLast) {
            TextButton finish = new TextButton("Finish", UiAssets.skin(), "sun");
            finish.addListener(new ChangeListener() {
                @Override public void changed(ChangeEvent e, Actor a) {
                    ScreenManager.get().setScreen(new CompleteScreen());
                }
            });
            root.add(finish).width(240).height(65).row();
        } else {
            TextButton next = new TextButton("Next Level  ▶", UiAssets.skin(), "sun");
            TextButton menu = new TextButton("Menu", UiAssets.skin());
            next.addListener(new ChangeListener() {
                @Override public void changed(ChangeEvent e, Actor a) {
                    ScreenManager.get().setScreen(new ChoosePlantScreen(level + 1));
                }
            });
            menu.addListener(new ChangeListener() {
                @Override public void changed(ChangeEvent e, Actor a) {
                    ScreenManager.get().setScreen(new StartupScreen());
                }
            });
            root.add(next).width(240).height(65).padBottom(14).row();
            root.add(menu).width(200).height(55).row();
        }
        stage.addActor(root);
    }

    @Override protected void update(float delta) { stage.act(delta); }

    @Override
    protected void draw() {
        DebugDraw dd = DebugDraw.get();
        batch.begin();
        dd.rect(batch, 0, 0, GameConfig.WORLD_WIDTH, GameConfig.WORLD_HEIGHT, BG);

        // Banner "LEVEL CLEARED!"
        bigFont.setColor(GOLD);
        layout.setText(bigFont, "LEVEL 1-" + level + "  CLEARED!");
        bigFont.draw(batch, "LEVEL 1-" + level + "  CLEARED!",
            (GameConfig.WORLD_WIDTH - layout.width) / 2f,
            GameConfig.WORLD_HEIGHT - 60f);
        batch.end();

        stage.draw();
    }

    @Override public void dispose() {
        super.dispose();
        stage.dispose();
        if (bigFont != null) bigFont.dispose();
    }
}
